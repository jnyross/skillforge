generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Core entities
// =============================================================================

model SkillRepo {
  id                       String         @id @default(uuid())
  slug                     String         @unique
  displayName              String
  description              String         @default("")
  defaultBranch            String         @default("main")
  currentChampionVersionId String?
  gitRepoPath              String
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  currentChampionVersion   SkillVersion?  @relation("ChampionVersion", fields: [currentChampionVersionId], references: [id], onDelete: SetNull)
  versions                 SkillVersion[] @relation("RepoVersions")
  lintResults              LintResult[]
  gitImportLogs            GitImportLog[]
  evalSuites               EvalSuite[]
  evalRuns                 EvalRun[]
  optimizerRuns            OptimizerRun[]
  reviewSessions           ReviewSession[]
  benchmarkSnapshots       BenchmarkSnapshot[]
  errorAnalysisSessions    ErrorAnalysisSession[]
  branches                 SkillBranch[]
  evalBuilderSessions      EvalBuilderSession[]
}

model SkillVersion {
  id              String    @id @default(uuid())
  skillRepoId     String
  branchName      String    @default("main")
  gitCommitSha    String
  parentVersionId String?
  commitMessage   String
  createdBy       String    @default("user")
  createdAt       DateTime  @default(now())
  tokenCount      Int       @default(0)
  lineCount       Int       @default(0)
  fileCount       Int       @default(0)
  linterScore     Float?
  isChampion      Boolean   @default(false)
  notes           String    @default("")

  skillRepo       SkillRepo @relation("RepoVersions", fields: [skillRepoId], references: [id], onDelete: Cascade)
  championOfRepo  SkillRepo[] @relation("ChampionVersion")
  parentVersion   SkillVersion? @relation("VersionLineage", fields: [parentVersionId], references: [id])
  childVersions   SkillVersion[] @relation("VersionLineage")
  lintResults     LintResult[]
  tags            VersionTag[]
  evalRuns        EvalRun[]    @relation("VersionEvalRuns")
  baselineEvalRuns EvalRun[]   @relation("BaselineEvalRuns")
  evalCaseRuns    EvalCaseRun[]
  traces          Trace[]
  candidateVersions OptimizerCandidate[] @relation("CandidateVersion")
  parentCandidates  OptimizerCandidate[] @relation("CandidateParentVersion")
  branchHeads       SkillBranch[] @relation("BranchHead")

  @@index([skillRepoId, createdAt])
  @@index([skillRepoId, branchName, createdAt])
}

model VersionTag {
  id              String       @id @default(uuid())
  skillVersionId  String
  name            String
  color           String       @default("default")
  createdAt       DateTime     @default(now())

  skillVersion    SkillVersion @relation(fields: [skillVersionId], references: [id], onDelete: Cascade)

  @@unique([skillVersionId, name])
  @@index([skillVersionId])
}

model GitImportLog {
  id              String    @id @default(uuid())
  skillRepoId     String
  sourceUrl       String
  status          String    @default("pending") // pending, cloning, importing, completed, failed
  error           String?
  skillVersionId  String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  skillRepo       SkillRepo @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)

  @@index([skillRepoId])
}

model LintResult {
  id              String    @id @default(uuid())
  skillRepoId     String
  skillVersionId  String?
  severity        String    // error | warning | info
  category        String
  rule            String
  message         String
  file            String    @default("SKILL.md")
  line            Int?
  evidence        String    @default("")
  createdAt       DateTime  @default(now())

  skillRepo       SkillRepo    @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  skillVersion    SkillVersion? @relation(fields: [skillVersionId], references: [id], onDelete: Cascade)

  @@index([skillRepoId])
  @@index([skillVersionId])
}

// =============================================================================
// Eval entities
// =============================================================================

model EvalSuite {
  id              String     @id @default(uuid())
  skillRepoId     String
  name            String
  type            String     // trigger | output | workflow | regression | blind | calibration
  splitPolicy     String     @default("random") // random | manual | hash
  version         Int        @default(1)
  frozen          Boolean    @default(false)
  description     String     @default("")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  skillRepo       SkillRepo  @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  cases           EvalCase[]
  evalRuns        EvalRun[]
  syntheticDataConfigs SyntheticDataConfig[]

  @@unique([skillRepoId, name])
  @@index([skillRepoId])
}

model EvalCase {
  id              String     @id @default(uuid())
  evalSuiteId     String
  key             String
  name            String
  prompt          String
  shouldTrigger   Boolean?
  expectedOutcome String     @default("")
  split           String     @default("train") // train | validation | holdout
  tags            String     @default("")
  configJson      String     @default("{}")
  judgeId         String?    // optional judge for Level 2 eval
  source          String     @default("manual") // manual | wizard | synthetic | error-analysis | promoted-trace
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  evalSuite       EvalSuite  @relation(fields: [evalSuiteId], references: [id], onDelete: Cascade)
  judge           JudgeDefinition? @relation(fields: [judgeId], references: [id], onDelete: SetNull)
  fixtures        EvalCaseFixture[]
  caseRuns        EvalCaseRun[]

  @@unique([evalSuiteId, key])
  @@index([evalSuiteId])
}

model EvalCaseFixture {
  id              String     @id @default(uuid())
  evalCaseId      String
  name            String
  type            String     // file | directory | env | config
  content         String
  path            String     @default("")
  createdAt       DateTime   @default(now())

  evalCase        EvalCase   @relation(fields: [evalCaseId], references: [id], onDelete: Cascade)

  @@index([evalCaseId])
}

model EvalRun {
  id                String     @id @default(uuid())
  skillRepoId       String
  skillVersionId    String
  baselineVersionId String?
  suiteId           String
  executorType      String     @default("claude-cli") // claude-cli | mock
  claudeVersion     String     @default("")
  model             String     @default("claude-opus-4-6")
  effort            String     @default("medium")
  permissionMode    String     @default("default")
  maxTurns          Int        @default(10)
  splitFilter       String     @default("all") // train | validation | train+validation | all
  status            String     @default("queued") // queued | running | completed | failed | cancelled
  startedAt         DateTime?
  completedAt       DateTime?
  metricsJson       String     @default("{}")
  error             String?
  jobId             String?
  createdAt         DateTime   @default(now())

  skillRepo         SkillRepo    @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  skillVersion      SkillVersion @relation("VersionEvalRuns", fields: [skillVersionId], references: [id])
  baselineVersion   SkillVersion? @relation("BaselineEvalRuns", fields: [baselineVersionId], references: [id])
  suite             EvalSuite    @relation(fields: [suiteId], references: [id])
  caseRuns          EvalCaseRun[]
  benchmarkSnapshots BenchmarkSnapshot[]
  traces            Trace[]

  @@index([skillRepoId])
  @@index([skillVersionId])
  @@index([suiteId])
  @@index([status])
}

model EvalCaseRun {
  id              String     @id @default(uuid())
  evalRunId       String
  evalCaseId      String
  skillVersionId  String
  attempt         Int        @default(1)
  status          String     @default("pending") // pending | running | passed | failed | error | skipped
  durationMs      Int?
  costUsd         Float?
  tokenUsage      String     @default("{}")
  triggerResult   Boolean?
  outputJson      String     @default("{}")
  error           String?
  traceId         String?
  evalFeedbackJson String    @default("{}") // Combined eval feedback from semantic grading
  allClaimsJson   String     @default("[]") // All claims extracted across all semantic assertions
  createdAt       DateTime   @default(now())

  evalRun         EvalRun    @relation(fields: [evalRunId], references: [id], onDelete: Cascade)
  evalCase        EvalCase   @relation(fields: [evalCaseId], references: [id])
  skillVersion    SkillVersion @relation(fields: [skillVersionId], references: [id])
  assertions      AssertionResult[]
  trace           Trace?     @relation("CaseRunTrace", fields: [traceId], references: [id])

  @@index([evalRunId])
  @@index([evalCaseId])
  @@index([status])
}

model AssertionResult {
  id              String     @id @default(uuid())
  evalCaseRunId   String
  name            String
  type            String     // exact | contains | regex | json-schema | file-exists | custom | semantic
  expected        String     @default("")
  actual          String     @default("")
  passed          Boolean
  message         String     @default("")
  durationMs      Int?
  evidence        String     @default("")   // Quoted text from output supporting verdict (semantic grading)
  reasoning       String     @default("")   // Why pass/fail with specific citations (semantic grading)
  confidence      Float?                     // 0-1 confidence score (semantic grading)
  dimension       String     @default("")   // structure | content | quality | format (semantic grading)
  claimsJson      String     @default("[]") // JSON array of ClaimVerification objects
  evalFeedbackJson String    @default("{}") // JSON EvalFeedback object
  createdAt       DateTime   @default(now())

  evalCaseRun     EvalCaseRun @relation(fields: [evalCaseRunId], references: [id], onDelete: Cascade)

  @@index([evalCaseRunId])
}

model BenchmarkSnapshot {
  id              String     @id @default(uuid())
  skillRepoId     String
  evalRunId       String
  totalCases      Int        @default(0)
  passedCases     Int        @default(0)
  failedCases     Int        @default(0)
  errorCases      Int        @default(0)
  skippedCases    Int        @default(0)
  passRate        Float      @default(0)
  avgDurationMs   Float?
  totalCostUsd    Float?
  metricsJson     String     @default("{}")
  createdAt       DateTime   @default(now())

  skillRepo       SkillRepo  @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  evalRun         EvalRun    @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@index([skillRepoId])
  @@index([evalRunId])
}

// =============================================================================
// Review entities
// =============================================================================

model ReviewSession {
  id              String     @id @default(uuid())
  skillRepoId     String
  name            String
  type            String     // blind-ab | pass-fail
  reviewer        String     @default("user")
  status          String     @default("active") // active | completed | abandoned
  totalPairs      Int        @default(0)
  completedPairs  Int        @default(0)
  configJson      String     @default("{}")
  createdAt       DateTime   @default(now())
  completedAt     DateTime?

  skillRepo       SkillRepo  @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  comparisons     PairwiseComparison[]
  labels          ReviewLabel[]

  @@index([skillRepoId])
  @@index([status])
}

model PairwiseComparison {
  id                String     @id @default(uuid())
  reviewSessionId   String
  evalCaseRunIdA    String
  evalCaseRunIdB    String
  versionIdA        String
  versionIdB        String
  order             Int        @default(0)
  createdAt         DateTime   @default(now())

  reviewSession     ReviewSession @relation(fields: [reviewSessionId], references: [id], onDelete: Cascade)
  votes             PreferenceVote[]

  @@index([reviewSessionId])
}

model PreferenceVote {
  id                String     @id @default(uuid())
  comparisonId      String
  selectedWinner    String     // A | B | tie | both-bad
  confidence        Float      @default(0.5)
  durationMs        Int?
  createdAt         DateTime   @default(now())

  comparison        PairwiseComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)

  @@index([comparisonId])
}

model ReviewLabel {
  id                String     @id @default(uuid())
  reviewSessionId   String
  evalCaseRunId     String
  label             String     // pass | fail
  confidence        Float      @default(0.5)
  createdAt         DateTime   @default(now())

  reviewSession     ReviewSession @relation(fields: [reviewSessionId], references: [id], onDelete: Cascade)
  critiques         Critique[]

  @@index([reviewSessionId])
  @@index([evalCaseRunId])
}

model Critique {
  id              String     @id @default(uuid())
  reviewLabelId   String
  content         String
  category        String     @default("")
  severity        String     @default("minor") // minor | major | critical
  createdAt       DateTime   @default(now())

  reviewLabel     ReviewLabel @relation(fields: [reviewLabelId], references: [id], onDelete: Cascade)

  @@index([reviewLabelId])
}

// =============================================================================
// Judge entities
// =============================================================================

model JudgeDefinition {
  id                  String     @id @default(uuid())
  name                String     @unique
  purpose             String     @default("")
  scope               String     @default("")
  targetCriterion     String     @default("")
  model               String     @default("claude-opus-4-6")
  outputSchema        String     @default("{}")
  status              String     @default("draft") // draft | candidate | calibrated | deprecated
  calibrationDatasetVersion String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  promptVersions      JudgePromptVersion[]
  calibrationRuns     JudgeCalibrationRun[]
  examples            JudgeExample[]
  evalCases           EvalCase[]
}

model JudgePromptVersion {
  id                String     @id @default(uuid())
  judgeId           String
  version           Int        @default(1)
  systemPrompt      String
  userPromptTemplate String
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())

  judge             JudgeDefinition @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  calibrationRuns   JudgeCalibrationRun[]

  @@unique([judgeId, version])
  @@index([judgeId])
}

model JudgeCalibrationRun {
  id                  String     @id @default(uuid())
  judgeId             String
  promptVersionId     String
  status              String     @default("pending") // pending | running | completed | failed
  totalExamples       Int        @default(0)
  truePositives       Int        @default(0)
  trueNegatives       Int        @default(0)
  falsePositives      Int        @default(0)
  falseNegatives      Int        @default(0)
  precision           Float?
  recall              Float?
  agreementRate       Float?
  metricsJson         String     @default("{}")
  jobId               String?
  createdAt           DateTime   @default(now())
  completedAt         DateTime?

  judge               JudgeDefinition @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  promptVersion       JudgePromptVersion @relation(fields: [promptVersionId], references: [id])

  @@index([judgeId])
  @@index([promptVersionId])
}

model JudgeExample {
  id              String     @id @default(uuid())
  judgeId         String
  input           String
  expectedLabel   String     // pass | fail
  humanCritique   String     @default("")
  split           String     @default("train") // train | validation | holdout
  createdAt       DateTime   @default(now())

  judge           JudgeDefinition @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  @@index([judgeId])
  @@index([split])
}

// =============================================================================
// Optimizer entities
// =============================================================================

model OptimizerRun {
  id                String     @id @default(uuid())
  skillRepoId       String
  baselineVersionId String
  suiteIds          String     @default("")
  maxIterations     Int        @default(10)
  maxBudgetUsd      Float?
  status            String     @default("queued") // queued | running | completed | stopped | failed
  currentIteration  Int        @default(0)
  objectiveJson     String     @default("{}")
  promotionRules    String     @default("{}")
  jobId             String?
  createdAt         DateTime   @default(now())
  startedAt         DateTime?
  completedAt       DateTime?

  skillRepo         SkillRepo  @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  candidates        OptimizerCandidate[]
  decisions         OptimizerDecision[]

  @@index([skillRepoId])
  @@index([status])
}

model OptimizerCandidate {
  id                  String     @id @default(uuid())
  optimizerRunId      String
  parentVersionId     String
  candidateVersionId  String?
  mutationType        String
  rationale           String     @default("")
  patchDiff           String     @default("")
  status              String     @default("queued") // queued | running | keep | discard | crash | blocked
  objectiveJson       String     @default("{}")
  runBudgetUsd        Float?
  error               String?
  createdAt           DateTime   @default(now())
  completedAt         DateTime?

  optimizerRun        OptimizerRun @relation(fields: [optimizerRunId], references: [id], onDelete: Cascade)
  parentVersion       SkillVersion @relation("CandidateParentVersion", fields: [parentVersionId], references: [id])
  candidateVersion    SkillVersion? @relation("CandidateVersion", fields: [candidateVersionId], references: [id])
  mutations           OptimizerMutation[]

  @@index([optimizerRunId])
  @@index([status])
}

model OptimizerMutation {
  id                String     @id @default(uuid())
  candidateId       String
  operator          String
  target            String     @default("")
  beforeSnippet     String     @default("")
  afterSnippet      String     @default("")
  createdAt         DateTime   @default(now())

  candidate         OptimizerCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

model OptimizerDecision {
  id                String     @id @default(uuid())
  optimizerRunId    String
  candidateId       String?
  decision          String     // keep | discard | crash | promote | stop
  reason            String     @default("")
  metricsJson       String     @default("{}")
  humanApproved     Boolean    @default(false)
  createdAt         DateTime   @default(now())

  optimizerRun      OptimizerRun @relation(fields: [optimizerRunId], references: [id], onDelete: Cascade)

  @@index([optimizerRunId])
}

// =============================================================================
// Trace entities
// =============================================================================

model Trace {
  id              String     @id @default(uuid())
  evalRunId       String?
  skillVersionId  String?
  sessionId       String     @default("")
  model           String     @default("")
  prompt          String     @default("")
  totalDurationMs Int?
  totalCostUsd    Float?
  totalTokens     Int?
  inputTokens     Int?
  outputTokens    Int?
  status          String     @default("pending") // pending | running | completed | failed
  resultJson      String     @default("{}")
  error           String?
  createdAt       DateTime   @default(now())
  completedAt     DateTime?

  evalRun         EvalRun?       @relation(fields: [evalRunId], references: [id], onDelete: SetNull)
  skillVersion    SkillVersion? @relation(fields: [skillVersionId], references: [id])
  toolEvents      ToolEvent[]
  artifacts       RunArtifact[]
  logChunks       LogChunk[]
  caseRuns        EvalCaseRun[] @relation("CaseRunTrace")
  errorAnalysisTraces ErrorAnalysisTrace[]

  @@index([evalRunId])
  @@index([skillVersionId])
  @@index([status])
}

model ToolEvent {
  id              String     @id @default(uuid())
  traceId         String
  toolName        String
  input           String     @default("")
  output          String     @default("")
  durationMs      Int?
  sequence        Int        @default(0)
  createdAt       DateTime   @default(now())

  trace           Trace      @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([traceId])
  @@index([traceId, sequence])
}

model RunArtifact {
  id              String     @id @default(uuid())
  traceId         String
  name            String
  type            String     // file | directory | stdout | stderr | json
  path            String     @default("")
  content         String     @default("")
  sizeBytes       Int        @default(0)
  createdAt       DateTime   @default(now())

  trace           Trace      @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([traceId])
}

model LogChunk {
  id              String     @id @default(uuid())
  traceId         String
  stream          String     @default("stdout") // stdout | stderr | system
  content         String
  sequence        Int        @default(0)
  timestamp       DateTime   @default(now())

  trace           Trace      @relation(fields: [traceId], references: [id], onDelete: Cascade)

  @@index([traceId])
  @@index([traceId, sequence])
}

// =============================================================================
// Wizard entities
// =============================================================================

model WizardDraft {
  id              String     @id @default(uuid())
  intent          String     @default("")
  mode            String     @default("scratch") // extract | synthesize | hybrid | scratch
  artifactsJson   String     @default("[]")
  configJson      String     @default("{}") // corrections, desiredOutputFormat, safetyConstraints, allowedTools
  concreteExamples String    @default("[]") // JSON array of concrete usage examples
  freedomLevel    String     @default("medium") // high | medium | low
  status          String     @default("intake") // intake | generating | review | saved | abandoned
  generatedSkill  String     @default("")
  generatedEvals  String     @default("{}")
  smokeResultJson String     @default("{}")
  savedVersionId  String?
  savedRepoId     String?
  // Interview state (PR 1: Conversational Intent Capture)
  interviewContextJson String @default("") // Serialized InterviewContext for resume
  interviewTranscript  String @default("") // Full interview transcript
  extractedAnswersJson String @default("[]") // JSON array of ExtractedAnswer objects
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

// =============================================================================
// Error Analysis entities
// =============================================================================

model ErrorAnalysisSession {
  id                String   @id @default(uuid())
  skillRepoId       String
  name              String
  description       String   @default("")
  status            String   @default("active") // active | saturated | archived
  samplingStrategy  String   @default("random") // random | outlier | failure-driven | uncertainty | stratified
  targetTraceCount  Int      @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  skillRepo         SkillRepo @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  traces            ErrorAnalysisTrace[]
  categories        FailureCategory[]

  @@index([skillRepoId])
}

model ErrorAnalysisTrace {
  id                  String    @id @default(uuid())
  analysisSessionId   String
  traceId             String
  sequence            Int       // order in which traces were reviewed
  openCodingNotes     String    @default("") // free-text notes (open coding)
  failureCategoryId   String?   // assigned category (axial coding)
  isNewFailureMode    Boolean   @default(false)
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())

  analysisSession     ErrorAnalysisSession @relation(fields: [analysisSessionId], references: [id], onDelete: Cascade)
  trace               Trace @relation(fields: [traceId], references: [id], onDelete: Cascade)
  failureCategory     FailureCategory? @relation(fields: [failureCategoryId], references: [id], onDelete: SetNull)

  @@index([analysisSessionId])
  @@index([traceId])
}

model FailureCategory {
  id                  String   @id @default(uuid())
  analysisSessionId   String
  name                String
  description         String   @default("")
  severity            String   @default("major") // minor | major | critical
  exampleTraceIds     String   @default("") // comma-separated trace IDs as exemplars
  count               Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  analysisSession     ErrorAnalysisSession @relation(fields: [analysisSessionId], references: [id], onDelete: Cascade)
  traces              ErrorAnalysisTrace[]

  @@index([analysisSessionId])
}

// =============================================================================
// Synthetic Data entities
// =============================================================================

model SyntheticDataConfig {
  id              String   @id @default(uuid())
  evalSuiteId     String
  name            String
  status          String   @default("draft") // draft | generating | review | committed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  evalSuite       EvalSuite @relation(fields: [evalSuiteId], references: [id], onDelete: Cascade)
  dimensions      SyntheticDimension[]
  generatedTuples SyntheticTuple[]

  @@index([evalSuiteId])
}

model SyntheticDimension {
  id              String   @id @default(uuid())
  configId        String
  name            String
  values          String   // JSON array of values
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  config          SyntheticDataConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

model SyntheticTuple {
  id              String   @id @default(uuid())
  configId        String
  dimensionValues String   // JSON object mapping dimension name -> value
  naturalLanguage String   @default("") // generated natural language prompt
  expectedOutcome String   @default("") // generated expected outcome
  included        Boolean  @default(true)
  evalCaseId      String?  // linked eval case once committed
  createdAt       DateTime @default(now())

  config          SyntheticDataConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
}

// =============================================================================
// Eval Builder (AI-guided conversation) entities
// =============================================================================

model EvalBuilderSession {
  id              String     @id @default(uuid())
  skillRepoId     String?
  title           String     @default("")
  phase           String     @default("understanding") // understanding | corpus | analysis | generation | refinement | committed
  status          String     @default("active") // active | committed | abandoned
  corpusText      String     @default("") // user-provided knowledge corpus
  analysisJson    String     @default("{}") // AI-extracted behaviors, edge cases, failure modes
  proposedCasesJson String   @default("[]") // AI-proposed test cases
  committedSuiteIds String   @default("") // comma-separated suite IDs after commit
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  skillRepo       SkillRepo? @relation(fields: [skillRepoId], references: [id], onDelete: SetNull)
  messages        EvalBuilderMessage[]

  @@index([status])
}

model EvalBuilderMessage {
  id              String     @id @default(uuid())
  sessionId       String
  role            String     // user | assistant | system
  content         String
  metadata        String     @default("{}") // JSON: proposed cases, actions taken, etc.
  createdAt       DateTime   @default(now())

  session         EvalBuilderSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

// =============================================================================
// Infrastructure entities
// =============================================================================

model JobRecord {
  id              String     @id @default(uuid())
  type            String     // eval-run | calibration | optimizer | wizard-generate
  status          String     @default("queued") // queued | running | completed | failed | cancelled
  payload         String     @default("{}")
  result          String     @default("{}")
  error           String?
  attempts        Int        @default(0)
  maxAttempts     Int        @default(3)
  priority        Int        @default(0)
  createdAt       DateTime   @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  @@index([type, status])
  @@index([status])
}

model ExecutorConfig {
  id              String     @id @default(uuid())
  name            String     @unique
  type            String     // claude-cli | mock
  isDefault       Boolean    @default(false)
  configJson      String     @default("{}")
  status          String     @default("active") // active | disabled
  lastHealthCheck DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model AuditLog {
  id              String     @id @default(uuid())
  action          String
  entityType      String     @default("")
  entityId        String     @default("")
  actor           String     @default("user")
  details         String     @default("{}")
  createdAt       DateTime   @default(now())

  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// =============================================================================
// Multi-tenant / user entities
// =============================================================================

model Workspace {
  id              String     @id @default(uuid())
  name            String
  slug            String     @unique
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  users           WorkspaceUser[]
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  displayName     String     @default("")
  role            String     @default("member") // admin | member | viewer
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workspaces      WorkspaceUser[]
}

model WorkspaceUser {
  id              String     @id @default(uuid())
  workspaceId     String
  userId          String
  role            String     @default("member") // admin | member | viewer
  createdAt       DateTime   @default(now())

  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model SkillBranch {
  id              String     @id @default(uuid())
  skillRepoId     String
  name            String
  headVersionId   String?
  isDefault       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  skillRepo       SkillRepo    @relation(fields: [skillRepoId], references: [id], onDelete: Cascade)
  headVersion     SkillVersion? @relation("BranchHead", fields: [headVersionId], references: [id], onDelete: SetNull)

  @@unique([skillRepoId, name])
  @@index([skillRepoId])
}
